{{!--
  partials/navigation.hbs
  ========================
  Used by the {{navigation}} and {{navigation type="secondary"}} helpers.
--}}

{{#if isSecondary}}
  <ul class="footer-links" role="menu">
    {{#foreach navigation}}
      <li class="{{link_class for=url class=(concat "nav-" slug)}}" role="menuitem">
        <a href="{{url absolute="true"}}">{{label}}</a>
      </li>
    {{/foreach}}
  </ul>
{{else}}
  <ul class="nav-list" role="menu">
    {{#foreach navigation}}
      <li class="nav-item {{link_class for=url class=(concat "nav-" slug)}}" role="menuitem">
        <a href="{{url absolute="true"}}" class="nav-link">{{label}}</a>
      </li>
    {{/foreach}}
  </ul>
{{/if}}
