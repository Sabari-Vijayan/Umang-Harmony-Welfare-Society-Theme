{{!--
  partials/footer.hbs
  =====================
  Included via {{> footer}} in default.hbs.

  Ghost helpers used:
  - {{@site.title}}         → site name
  - {{@site.url}}           → base URL
  - {{@site.description}}   → tagline from Ghost Admin
  - {{asset "..."}}         → resolves theme assets
  - {{date format="YYYY"}}  → outputs current year (used for copyright)
--}}

<footer class="site-footer" role="contentinfo">

  {{!-- Pre-footer CTA band --}}
  <div class="footer-cta-band">
    <div class="container footer-cta-inner">
      <div class="footer-cta-text">
        <h2>{{@custom.footer_tagline}}</h2>
        <p>Support women-led income generation, strengthen market access, or collaborate on financial inclusion.</p>
      </div>
      <div class="footer-cta-actions">
        <a href="{{@site.url}}/partner-with-us/" class="btn btn-outline-white">Partner With Us</a>
        <a href="{{@site.url}}/contact/" class="btn btn-white">Get In Touch</a>
      </div>
    </div>
  </div>

  {{!-- Main footer grid --}}
  <div class="footer-main">
    <div class="container footer-grid">

      {{!-- Column 1: About --}}
      <div class="footer-col footer-col--about">
        {{#if @site.logo}}
          <a href="{{@site.url}}">
            <img src="{{@site.logo}}" alt="{{@site.title}}" class="footer-logo" width="150" height="52">
          </a>
        {{else}}
          <a href="{{@site.url}}" class="footer-site-name">{{@site.title}}</a>
        {{/if}}
        <p class="footer-tagline">
          {{@custom.footer_tagline}}
        </p>
        <p class="footer-reg">{{@custom.footer_registration}}</p>
        <div class="footer-social">
          {{#if @site.facebook}}
          <a href="{{facebook_url @site.facebook}}" class="social-link social-link--footer" aria-label="Facebook" rel="noopener noreferrer" target="_blank">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
          </a>
          {{/if}}
          {{#if @site.twitter}}
          <a href="{{twitter_url @site.twitter}}" class="social-link social-link--footer" aria-label="Twitter" rel="noopener noreferrer" target="_blank">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M23 3a10.9 10.9 0 0 1-3.14 1.53 4.48 4.48 0 0 0-7.86 3v1A10.66 10.66 0 0 1 3 4s-4 9 5 13a11.64 11.64 0 0 1-7 2c9 5 20 0 20-11.5a4.5 4.5 0 0 0-.08-.83A7.72 7.72 0 0 0 23 3z"/></svg>
          </a>
          {{/if}}
        </div>
      </div>

      {{!-- Column 2: Quick Links --}}
      <div class="footer-col">
        <h3 class="footer-heading">Quick Links</h3>
        {{navigation}}
      </div>

      {{!-- Column 3: Our Work --}}
      <div class="footer-col">
        <h3 class="footer-heading">Our Programmes</h3>
        {{navigation type="secondary"}}
      </div>

      {{!-- Column 4: Contact --}}
      <div class="footer-col">
        <h3 class="footer-heading">Contact Us</h3>
        <address class="footer-address">
          <p>
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/></svg>
            {{@custom.contact_address}}
          </p>
          <p>
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M20 4H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"/></svg>
            <a href="mailto:{{@custom.contact_email}}">{{@custom.contact_email}}</a>
          </p>
        </address>
      </div>

    </div>
  </div>

  {{!-- Bottom bar --}}
  <div class="footer-bottom">
    <div class="container footer-bottom-inner">
      <p class="copyright">
        &copy; {{date format="YYYY"}} {{@site.title}}. All rights reserved.
      </p>
      <p class="footer-bottom-links">
        <a href="{{@site.url}}/terms-conditions/">Terms &amp; Conditions</a>
        <span aria-hidden="true">·</span>
        <a href="{{@site.url}}/privacy-policy/">Privacy Policy</a>
      </p>
    </div>
  </div>

</footer>
