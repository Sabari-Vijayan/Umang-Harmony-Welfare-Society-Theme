{{!< default}}

{{#contentFor "styles"}}
    <link rel="stylesheet" type="text/css" href="{{asset "css/about-page.css"}}" />
{{/contentFor}}

{{#post}}
<article class="about-page {{post_class}}">

    {{!-- 1. Narrative Hero --}}
    <header class="about-hero {{#if feature_image}}has-image{{/if}}" 
            {{#if feature_image}}style="background-image: url('{{feature_image}}');"{{/if}}>
        <div class="container">
            <div class="about-hero-content">
                <span class="about-eyebrow">Our Journey</span>
                <h1 class="about-title">{{title}}</h1>
                {{#if custom_excerpt}}
                    <p class="about-lead">{{custom_excerpt}}</p>
                {{/if}}
            </div>
        </div>
    </header>

    {{!-- 2. Leadership Section --}}
    <section class="about-leadership section-padding">
        <div class="container">
            <div class="section-header text-center">
                <h2 class="section-title">Our Leadership</h2>
                <p class="section-subtitle">The vision and passion behind Umang Harmony.</p>
            </div>
            <div class="founders-grid">
                {{#get "posts" filter="tag:hash-founder" limit="2" include="tags,authors" order="published_at asc"}}
                    {{#foreach posts}}
                        <div class="founder-card">
                            <div class="founder-image {{#if feature_image}}has-image{{/if}}"
                                 {{#if feature_image}}style="background-image: url('{{feature_image}}');"{{/if}}>
                            </div>
                            <div class="founder-info">
                                <h3 class="founder-name">{{title}}</h3>
                                {{#if custom_excerpt}}
                                    <p class="founder-role">{{custom_excerpt}}</p>
                                {{/if}}
                                <div class="founder-bio">
                                    {{content}}
                                </div>
                            </div>
                        </div>
                    {{/foreach}}
                {{/get}}
            </div>
        </div>
    </section>

    {{!-- 3. Main Narrative Content --}}
    <section class="about-body section-padding">
        <div class="container">
            <div class="about-content-grid">
                
                {{!-- The "gh-content" class ensures standard Ghost editor styles apply, 
                      but we will add specific "about-page" overrides in the CSS --}}
                <div class="gh-content about-main-text">
                    {{{content}}}
                </div>

                {{!-- A side "quick-facts" or "impact-box" can be added here if needed, 
                      but for now, we'll keep it clean and focused on the story --}}
            </div>
        </div>
    </section>

    {{!-- 4. Values / Highlight Section (Placeholder for Visual Impact) --}}
    {{!-- This section uses a subtle background to break up the long text --}}
    <section class="about-highlights section-padding section-bg-light">
        <div class="container">
            <div class="highlights-grid">
                <div class="highlight-item">
                    <div class="highlight-image-top">
                        <span class="highlight-icon">🤝</span>
                    </div>
                    <div class="highlight-item-body">
                        <h3>Community First</h3>
                        <p>{{@custom.about_highlight_1_description}}</p>
                    </div>
                </div>
                <div class="highlight-item">
                    <div class="highlight-image-top">
                        <span class="highlight-icon">📈</span>
                    </div>
                    <div class="highlight-item-body">
                        <h3>Sustainable Growth</h3>
                        <p>{{@custom.about_highlight_2_description}}</p>
                    </div>
                </div>
                <div class="highlight-item">
                    <div class="highlight-image-top">
                        <span class="highlight-icon">⚖️</span>
                    </div>
                    <div class="highlight-item-body">
                        <h3>Financial Agency</h3>
                        <p>{{@custom.about_highlight_3_description}}</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

</article>
{{/post}}
