{{!< default}}

{{#post}}

<header class="works-header {{#if feature_image}}has-image{{/if}}" 
     {{#if feature_image}}style="background-image: url('{{feature_image}}');"{{/if}}>
    <div class="container">
        <div class="works-header-content">
            <h1 class="works-title">{{title}}</h1>
            {{#if custom_excerpt}}
                <p class="works-lead">{{custom_excerpt}}</p>
            {{/if}}
            <div class="works-search">
                <button class="btn btn-outline-white search-trigger" data-ghost-search>
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
                    Search Initiatives...
                </button>
            </div>
            
            {{!-- Scroll indicator --}}
            <a href="#works-content" class="scroll-down" aria-label="Scroll down to content">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M7 13l5 5 5-5M7 6l5 5 5-5"/></svg>
            </a>
        </div>
    </div>
</header>

<div id="works-content" class="works-page-content section-padding">
    <div class="container container--narrow">
        
        {{!-- 1. Page Content from Ghost Editor --}}
        <div class="works-intro gh-content">
            {{{content}}}
        </div>

        {{!-- 2. Vertical Works List --}}
        <div class="works-list">
            {{#get "posts" filter="tag:-hash-founder+tag:-hash-contact-person" limit="100" include="tags,authors" order="published_at desc"}}
                {{#foreach posts}}
                    <article class="work-item">
                        
                        {{#if feature_image}}
                        <a href="{{url}}" class="work-image-link" aria-label="{{title}}">
                            <img src="{{img_url feature_image size="m"}}" alt="{{title}}" class="work-image" loading="lazy">
                        </a>
                        {{/if}}

                        <div class="work-content">
                            <span class="work-meta">{{date format="DD MMM YYYY"}} {{#if primary_tag}}· {{primary_tag.name}}{{/if}}</span>
                            <h2 class="work-item-title">
                                <a href="{{url}}">{{title}}</a>
                            </h2>
                            <p class="work-excerpt">{{excerpt words="30"}}</p>
                            <a href="{{url}}" class="work-link">Read Full Story →</a>
                        </div>

                    </article>
                {{else}}
                    <p class="no-posts">Our latest initiatives are currently being documented. Check back soon!</p>
                {{/foreach}}
            {{/get}}
        </div>

    </div>
</div>

{{/post}}
