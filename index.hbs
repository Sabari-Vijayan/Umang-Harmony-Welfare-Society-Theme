{{!< default}}
{{!--
  index.hbs
  ==========
  Homepage template for Umang Harmony Welfare Society.
  Ghost automatically uses this file for the root URL (/).

  Key Ghost Handlebars helpers used here:
  {{#foreach posts}}   → loops over the current page's posts
  {{title}}            → post title
  {{excerpt}}          → auto-generated excerpt
  {{feature_image}}    → featured image URL
  {{url}}              → the post's full URL
  {{primary_tag}}      → the first tag assigned to the post
  {{published_at}}     → publish date
  {{reading_time}}     → estimated reading time
  {{pagination}}       → renders prev/next page links
--}}

{{!-- 1. HERO SECTION --}}
<section class="hero" aria-label="Hero banner">
  <div class="hero-slides">
    <div class="hero-slide is-active" style="background-image: url('{{@site.cover_image}}')">
      <div class="hero-overlay"></div>
      <div class="container hero-content">
        {{#if @site.logo}}
          <span class="hero-tag">{{@site.title}}</span>
        {{else}}
          <span class="hero-tag">{{@site.title}}</span>
        {{/if}}
        <h1 class="hero-title">{{@custom.hero_title}}</h1>
        <p class="hero-subtitle">{{@custom.hero_subtitle}}</p>
        <div class="hero-actions">
          <a href="{{@site.url}}/about/" class="btn btn-primary btn-lg">Our Story</a>
          <a href="{{@site.url}}/partner-with-us/" class="btn btn-outline-white btn-lg">Partner With Us</a>
        </div>
      </div>
    </div>
  </div>
</section>

{{!-- 2. IMPACT STATS BAR --}}
<section class="stats-bar" aria-label="Impact statistics">
  <div class="container stats-inner">
    <div class="stat-item">
      <span class="stat-number" data-target="{{@custom.women_engaged}}">0</span>
      <span class="stat-label">Women Engaged</span>
    </div>
    <div class="stat-divider" aria-hidden="true"></div>
    <div class="stat-item">
      <span class="stat-number" data-target="{{@custom.women_earning}}">0</span>
      <span class="stat-label">Women Earning</span>
    </div>
    <div class="stat-divider" aria-hidden="true"></div>
    <div class="stat-item">
      <span class="stat-number" data-target="{{@custom.villages_covered}}">0</span>
      <span class="stat-label">Villages Covered</span>
    </div>
    <div class="stat-divider" aria-hidden="true"></div>
    <div class="stat-item">
      <span class="stat-number" data-target="{{@custom.sroi}}">0</span>
      <span class="stat-label">SROI</span>
    </div>
  </div>
</section>

{{!-- 3. ABOUT STRIP --}}
<section class="about-strip section-padding" aria-label="About Umang Harmony Welfare Society">
  <div class="container about-strip-inner">
    <div class="about-strip-text">
      <span class="section-eyebrow">Who We Are</span>
      <h2 class="section-title">A Livelihood-Focused Organisation</h2>
      <p>{{@custom.about_section_description}}</p>
      <a href="{{@site.url}}/about/" class="btn btn-primary">Read More</a>
    </div>
    <div class="about-strip-visual">
      <img src="{{@custom.madhya_pradesh_image}}" alt="Madhya Pradesh" class="mission-image">
    </div>
  </div>
</section>

{{!-- 4. OUR ACTIVITIES (Ghost Posts) --}}
<section class="latest-posts section-padding section-bg-light" aria-label="Latest activities">
  <div class="container">
    <div class="section-header">
      <span class="section-eyebrow">What We Do?</span>
      <h2 class="section-subtitle what-we-do">Empowering communities through sustainable initiatives.</h2>
    </div>


<div class="posts-grid">
  {{!-- 
    1. 'get' fetches posts specifically 
    2. 'filter' looks for the internal tag #case-story (represented as hash-case-story)
    3. 'include' ensures we get the tag data for the labels 
  --}}
  {{#get "posts" filter="tag:hash-case-story" limit="3" include="tags,authors"}}
    {{#foreach posts}}
      <article class="post-card">
        {{#if feature_image}}
          <a href="{{url}}" class="post-card-image-link" tabindex="-1" aria-hidden="true">
            {{!-- Using <img> tag with srcset is better for performance than background-image --}}
            <img class="post-card-image"
              srcset="{{img_url feature_image size="s"}} 300w,
                      {{img_url feature_image size="m"}} 600w"
              src="{{img_url feature_image size="m"}}"
              alt="{{#if feature_image_alt}}{{feature_image_alt}}{{else}}{{title}}{{/if}}"
              loading="lazy"
            />
            {{#primary_tag}}
              <span class="post-card-tag">{{name}}</span>
            {{/primary_tag}}
          </a>
        {{/if}}

        <div class="post-card-body">
          <div class="post-card-meta">
            <time datetime="{{date format="YYYY-MM-DD"}}">{{date format="DD MMM YYYY"}}</time>
          </div>
          
          <h3 class="post-card-title">
            <a href="{{url}}">{{title}}</a>
          </h3>
          
          {{!-- Use custom_excerpt if available, otherwise fallback to auto-generated excerpt --}}
          <p class="post-card-excerpt">
            {{#if custom_excerpt}}
              {{custom_excerpt}}
            {{else}}
              {{excerpt words="20"}}
            {{/if}}
          </p>
          
          <a href="{{url}}" class="post-card-link">Read Case Story →</a>
        </div>
      </article>
    {{/foreach}}
  {{else}}
    {{!-- This shows if no posts with that tag are found --}}
    <p class="no-posts">Our latest impact stories are being documented. Check back soon!</p>
  {{/get}}
</div>


    <div class="section-footer-link">
      <a href="{{@site.url}}/our-works/" class="btn btn-outline">View All Updates</a>
    </div>
  </div>
</section>

{{!-- 5. MISSION HIGHLIGHT --}}
<section class="mission-highlight section-padding mission-highlight-green">
  {{#get "posts" filter="tag:hash-flagship-programme" limit="1" include="tags,authors"}}
    {{#foreach posts}}
      <div class="container mission-inner">
        <div class="mission-visual" aria-hidden="true">
          {{#if feature_image}}
            <img src="{{feature_image}}" alt="{{title}}" class="mission-image">
          {{else}}
            <div class="mission-plant-icon">💰</div>
          {{/if}}
        </div>
        <div class="mission-text">
          <span class="section-eyebrow">Flagship Programmes</span>
          <h2 class="section-title">{{title}}</h2>
          <p>{{excerpt words="40"}}</p>
          <a href="{{url}}" class="btn btn-accent">Read More</a>
        </div>
      </div>
    {{/foreach}}
  {{else}}
    <div class="container mission-inner">
      <div class="mission-visual" aria-hidden="true">
        {{#if @custom.flagship_image}}
          <img src="{{@custom.flagship_image}}" alt="{{@custom.flagship_section_title}}" class="mission-image">
        {{else}}
          <div class="mission-plant-icon">💰</div>
        {{/if}}
      </div>
      <div class="mission-text">
        <span class="section-eyebrow">Flagship Programmes</span>
        <h2 class="section-title">Cotton Wick Production</h2>
        <p>{{@custom.flagship_section_description}}</p>
        <a href="{{@site.url}}/flagship-programme/" class="btn btn-accent">Read More</a>
      </div>
      </div>
      {{/get}}
      </section>

      {{!-- 6. IMPACT STORY STRIP --}}
      <section class="impact-story section-padding section-bg-light {{#if @custom.impact_story_image}}has-bg-image{{/if}}" 
           aria-label="Impact story"
           {{#if @custom.impact_story_image}}style="background-image: url('{{@custom.impact_story_image}}');"{{/if}}>
      <div class="container">
      <div class="section-header">
        <span class="section-eyebrow">Impact Story</span>
        <h2 class="section-title">A Spark That Lit 300 Lives</h2>
      </div>    <div class="impact-story-content">
      <p>{{@custom.impact_story_content}}</p>
      <a href="{{@site.url}}/impact-story/" class="btn btn-outline">See Full Impact</a>
    </div>
  </div>
</section>

{{!-- Ghost pagination --}}
{{#if pagination.pages}}
  {{#if pagination.prev}}
    <div class="pagination-wrapper">
      {{pagination}}
    </div>
  {{/if}}
{{/if}}
