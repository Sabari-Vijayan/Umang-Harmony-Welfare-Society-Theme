{{!< default}}

{{#post}}
<article class="partner-page {{post_class}}">

    {{!-- 1. Hero Section --}}
    <header class="partner-hero {{#if feature_image}}has-image{{/if}}" 
            {{#if feature_image}}style="background-image: url('{{feature_image}}');"{{/if}}>
        <div class="container">
            <div class="partner-hero-content">
                <span class="partner-eyebrow">Collaborate with Umang</span>
                <h1 class="partner-title">{{title}}</h1>
                {{#if custom_excerpt}}
                    <p class="partner-lead">{{custom_excerpt}}</p>
                {{/if}}
            </div>
        </div>
    </header>

    {{!-- 2. Introductory Content --}}
    <section class="partner-intro section-padding">
        <div class="container container--narrow">
            <div class="gh-content">
                {{{content}}}
            </div>
        </div>
    </section>

    {{!-- 3. Partnership Sections --}}
    <section class="partner-options-section section-padding section-bg-light">
        <div class="container">
            <div class="partner-grid">
                {{#get "posts" filter="tag:hash-partnership" limit="3" include="tags" order="published_at asc"}}
                    {{#foreach posts}}
                        {{!-- Using #highlight tag to apply the card-highlight class --}}
                        <div class="partner-card {{#has tag="#highlight"}}card-highlight{{/has}}">
                            {{#if feature_image}}
                                <div class="partner-card-image">
                                    <img src="{{img_url feature_image size="m"}}" alt="{{title}}" loading="lazy">
                                </div>
                            {{/if}}
                            <div class="partner-card-content">
                                <h3>{{title}}</h3>
                                <p>{{excerpt}}</p>
                                {{!-- The content of the post is used as the button label --}}
                                <a href="{{canonical_url}}" 
                                   class="btn {{#has tag="#highlight"}}btn-accent{{else}}btn-primary{{/has}}" 
                                   target="_blank" 
                                   rel="noopener">
                                    {{content}}
                                </a>
                            </div>
                        </div>
                    {{/foreach}}
                {{else}}
                    <p class="no-posts">Our partnership opportunities are currently being updated. Please check back soon!</p>
                {{/get}}
            </div>
        </div>
    </section>

    {{!-- 4. Final CTA / Support Text --}}
    <section class="partner-footer section-padding">
        <div class="container container--narrow text-center">
            <h2 class="section-title">Not sure where to start?</h2>
            <p class="section-subtitle">Reach out to us directly and we can discuss how you can best support our mission in Madhya Pradesh.</p>
            <a href="{{@site.url}}/contact-us/" class="btn btn-outline">Contact Our Team</a>
        </div>
    </section>

</article>
{{/post}}
