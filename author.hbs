{{!< default}}
{{!--
  author.hbs
  ==========
  Template for author profile pages.
--}}

<div class="author-header section-padding">
  <div class="container">
    {{#author}}
      <div class="author-profile">
        {{#if profile_image}}
          <img src="{{profile_image}}" alt="{{name}}" class="author-avatar" width="100" height="100">
        {{else}}
          <div class="author-avatar author-avatar--placeholder" aria-hidden="true">{{name.[0]}}</div>
        {{/if}}
        <div class="author-details">
          <span class="section-eyebrow">Author</span>
          <h1 class="section-title">{{name}}</h1>
          {{#if bio}}
            <p class="section-subtitle">{{bio}}</p>
          {{/if}}
          <div class="author-meta">
            {{#if location}}<span>📍 {{location}}</span>{{/if}}
            {{#if website}}<span><a href="{{website}}" target="_blank" rel="noopener noreferrer">🌐 Website</a></span>{{/if}}
            <span><a href="{{@custom.linkedin_url}}" target="_blank" rel="noopener noreferrer">LinkedIn</a></span>
          </div>
        </div>
      </div>
    {{/author}}
  </div>
</div>

<main class="container section-padding">
  <div class="posts-grid">
    {{#foreach posts}}
      <article class="post-card">
        {{#if feature_image}}
          <a href="{{url}}" class="post-card-image-link" tabindex="-1" aria-hidden="true">
            <div class="post-card-image" style="background-image: url('{{img_url feature_image size="m"}}')">
              {{#primary_tag}}
                <span class="post-card-tag">{{name}}</span>
              {{/primary_tag}}
            </div>
          </a>
        {{/if}}
        <div class="post-card-body">
          <div class="post-card-meta">
            <time datetime="{{date format="YYYY-MM-DD"}}">{{date format="DD MMM YYYY"}}</time>
            {{#if reading_time}}
              <span class="post-reading-time">· {{reading_time}} min read</span>
            {{/if}}
          </div>
          <h3 class="post-card-title">
            <a href="{{url}}">{{title}}</a>
          </h3>
          <p class="post-card-excerpt">{{excerpt words="20"}}</p>
          <a href="{{url}}" class="post-card-link">Read More →</a>
        </div>
      </article>
    {{else}}
      <p class="no-posts">No posts published by this author yet.</p>
    {{/foreach}}
  </div>

  {{pagination}}
</main>
